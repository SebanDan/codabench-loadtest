# Target Codabench instance
CODABENCH_HOST=http://localhost:8000

# Authentication (token OR username/password)
CODABENCH_USERNAME=admin
CODABENCH_PASSWORD=12345

# Polling behavior (seconds)
CODABENCH_POLL_INTERVAL=5.0
CODABENCH_POLL_TIMEOUT=3600.0

# Competition to target
CODABENCH_COMPETITION_ID=2
CODABENCH_COMPETITION_BUNDLE=Mini-MNIST-Bundle.zip

# Performance thresholds
CODABENCH_MAX_RESPONSE_TIME_P95=2.0
CODABENCH_MAX_ERROR_RATE=0.01

# MinIO (optional, for storage monitoring)
CODABENCH_MINIO_ENDPOINT=http://localhost:9000

# RabbitMQ (optional, for queue monitoring)
CODABENCH_RABBITMQ_URL=http://localhost:15672
CODABENCH_RABBITMQ_USER=guest
